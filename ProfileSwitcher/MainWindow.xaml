<Window x:Class="ProfileSwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AMD Power Profile Switcher"
        Width="520" Height="600"
        MinWidth="480" MinHeight="560"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>   <!-- Power display -->
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>   <!-- PowerSaver card -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>   <!-- GamingMode card -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Title + Settings gear -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="AMD Power Profile Switcher"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtHardware" Text=""
                           FontSize="12" Foreground="{StaticResource TextDimBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
            <Button x:Name="btnSettings" Content="⚙" FontSize="20"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="Transparent" Foreground="{StaticResource TextDimBrush}"
                    BorderThickness="0" Cursor="Hand" Padding="4,0"
                    ToolTip="Settings"/>
        </Grid>

        <!-- Live power display -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}"
                CornerRadius="10" Padding="16,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="W A L L   P O W E R   ( N E T I O )" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDimBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtPower" Text="---"
                           FontSize="42" FontWeight="Bold"
                           Foreground="{StaticResource BlueBrush}"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                <TextBlock x:Name="txtPowerLabel" Text="Connecting..."
                           FontSize="11" Foreground="{StaticResource TextDimBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- PowerSaver -->
        <Border Grid.Row="4" Background="{StaticResource CardBrush}"
                CornerRadius="10" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="dotPowerSaver" Width="10" Height="10"
                                 Fill="#FF555555" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="PowerSaver" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="txtPsDetails" Text=""
                               FontSize="11" Foreground="{StaticResource TextDimBrush}"
                               Margin="18,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="btnPowerSaver"
                        Content="APPLY" Style="{StaticResource ProfileButton}"
                        Background="{StaticResource GreenBrush}"
                        Width="100" Height="48"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- GamingMode -->
        <Border Grid.Row="6" Background="{StaticResource CardBrush}"
                CornerRadius="10" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="dotGamingMode" Width="10" Height="10"
                                 Fill="#FF555555" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="GamingMode" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="txtGmDetails" Text=""
                               FontSize="11" Foreground="{StaticResource TextDimBrush}"
                               Margin="18,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="btnGamingMode"
                        Content="APPLY" Style="{StaticResource ProfileButton}"
                        Background="{StaticResource RedBrush}"
                        Width="100" Height="48"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="8" Background="#0DFFFFFF" CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
            <TextBlock x:Name="txtStatus" Text="Ready"
                       FontSize="12" Foreground="{StaticResource TextDimBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
